# Database (async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://shorturl:shorturl@localhost:5432/shorturl

# Cache backend: "memory" (single instance) or "redis" (shared, for production)
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=10000

# Alias generation
ALIAS_LENGTH=7
ALIAS_MAX_RETRIES=5

# Public base URL used to build returned short_url values (no trailing slash)
BASE_URL=http://localhost:8000

# Create DB schema on startup
CREATE_SCHEMA_ON_STARTUP=true
